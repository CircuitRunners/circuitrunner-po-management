# Copy to .env for local testing with the Functions emulator.
# Production: set the same keys in Google Cloud for the deployed function (functions/.env is NOT used in prod).

# --- Why no emails on localhost? ---
# Vite does NOT run Cloud Functions. Either:
#   A) Deploy: firebase deploy --only functions  → set SMTP_* in Google Cloud Run env for the function.
#   B) Emulator: terminal 1: npm run emulators (from repo root)
#              terminal 2: add VITE_USE_FIRESTORE_EMULATOR=true to ROOT .env, then npm run dev
#              (Emulator Firestore starts empty — import data or create users/POs in Emulator UI :4000)

# --- Gmail / Google Workspace (@circuitrunners.com) ---
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=po-notifications@circuitrunners.com
# SMTP_PASS=xxxx xxxx xxxx xxxx
# SMTP_FROM=PO System <po-notifications@circuitrunners.com>

# --- Optional: links in notification emails ---
# APP_BASE_URL=https://your-app.netlify.app
